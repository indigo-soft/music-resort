#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';
if (!function_exists('__')) {
    require_once __DIR__ . '/../src/Helpers/helpers.php';
}

use MusicResort\Command\CleanEmptyDirsCommand;
use MusicResort\Command\CleanMp3Command;
use MusicResort\Command\DeduplicateMp3Command;
use MusicResort\Command\FixExtensionsCommand;
use MusicResort\Command\MetadataEnrichCommand;
use MusicResort\Command\MetadataScanCommand;
use MusicResort\Command\MigrateCommand;
use MusicResort\Command\MigrateRefreshCommand;
use MusicResort\Command\ResortMp3Command;
use MusicResort\Command\RunAllCommand;
use MusicResort\Database\Migration\DatabaseMigrationService;
use MusicResort\Database\Repository\AudioProcessingRepository;
use MusicResort\Database\Repository\LastFmTagRepository;
use MusicResort\Database\Repository\MusicFileMetadataRepository;
use MusicResort\Database\Repository\ProcessingLogRepository;
use MusicResort\Http\PhpHttpClient;
use MusicResort\Logger\DatabaseLoggerService;
use MusicResort\Service\ConfigService;
use MusicResort\Service\LastFmClient;
use MusicResort\Service\LocalizationService;
use MusicResort\Service\MetadataEnrichService;
use MusicResort\Service\MetadataScanService;
use MusicResort\Service\MusicMetadataServiceFactory;
use Symfony\Component\Console\Application;

// -------------------------------------------------------------------------
// Bootstrap: configuration & localization
// -------------------------------------------------------------------------

$projectRoot = dirname(__DIR__);

ConfigService::init($projectRoot);
LocalizationService::setLocale(ConfigService::get('app.default_lang'));

// -------------------------------------------------------------------------
// Infrastructure: database connection validation
// -------------------------------------------------------------------------

$dbHost = (string) ConfigService::get('app.db_host');
$dbPort = (string) ConfigService::get('app.db_port');
$dbName = (string) ConfigService::get('app.db_name');
$dbUser = (string) ConfigService::get('app.db_user');
$dbPass = (string) ConfigService::get('app.db_password');

if ($dbHost === '' || $dbName === '' || $dbUser === '') {
    fwrite(STDERR, '[music-resort] DB_HOST, DB_NAME, and DB_USER must be set in .env' . PHP_EOL);
    exit(1);
}

// -------------------------------------------------------------------------
// Infrastructure: database connection
// -------------------------------------------------------------------------

try {
    $dsn = sprintf(
        'mysql:host=%s;port=%s;dbname=%s;charset=utf8mb4',
        $dbHost,
        $dbPort ?: '3306',
        $dbName,
    );

    $pdo = new PDO($dsn, $dbUser, $dbPass, [
        PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        PDO::ATTR_PERSISTENT         => false,
        \Pdo\Mysql::ATTR_INIT_COMMAND => 'SET NAMES utf8mb4 COLLATE utf8mb4_unicode_ci',
    ]);

    $audioProcessingRepository   = new AudioProcessingRepository($pdo);
    $processingLogRepository     = new ProcessingLogRepository($pdo);
    $musicFileMetadataRepository = new MusicFileMetadataRepository($pdo);
    $lastFmTagRepository         = new LastFmTagRepository($pdo);
} catch (Throwable $e) {
    fwrite(STDERR, '[music-resort] Database connection failed: ' . $e->getMessage() . PHP_EOL);
    fwrite(STDERR, 'Check DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD in .env' . PHP_EOL);
    exit(1);
}

// -------------------------------------------------------------------------
// Infrastructure: logger
//
// A UUIDv4 run_id groups all log entries from this invocation.
// Command-level loggers will be wired per-command in v1.1.0 DI fix.
// -------------------------------------------------------------------------

$runId  = DatabaseLoggerService::generateRunId();
$logger = new DatabaseLoggerService($processingLogRepository, 'console', $runId);

// -------------------------------------------------------------------------
// Infrastructure: migration service
// -------------------------------------------------------------------------

$migrationsPath   = $projectRoot . '/db/migrations';
$migrationService = new DatabaseMigrationService($pdo, $migrationsPath);

// -------------------------------------------------------------------------
// Infrastructure: preserve tables for migrate:refresh
//
// Defaults: migrations, processing_log
// Override via MIGRATION_PRESERVE_TABLES in .env (comma-separated).
// -------------------------------------------------------------------------

$rawPreserve    = (string) ConfigService::get('app.migration_preserve_tables');
$preserveTables = $rawPreserve !== ''
    ? array_map('trim', explode(',', $rawPreserve))
    : ['migrations', 'processing_log'];

// -------------------------------------------------------------------------
// Infrastructure: Last.fm enrichment
//
// PhpHttpClient (file_get_contents-based, zero dependencies) -> LastFmClient
// -> MetadataEnrichService. API key is validated inside the command so that
// the rest of the application keeps working without it.
// -------------------------------------------------------------------------

$lastFmApiKey = (string) ConfigService::get('app.lastfm_api_key');

$httpClient = new PhpHttpClient();
$lastFm     = new LastFmClient(
    $lastFmApiKey,
    (string) ConfigService::get('app.lastfm_api_url'),
    $httpClient,
);

$metadataEnrichService = new MetadataEnrichService(
    $musicFileMetadataRepository,
    $lastFmTagRepository,
    $lastFm,
    $logger,
    (int) ConfigService::get('app.lastfm_cache_ttl_days'),
);

// -------------------------------------------------------------------------
// Infrastructure: metadata scan
//
// MusicMetadataServiceFactory creates a per-file MusicMetadataService
// (getID3, ADR-0003); MetadataScanService inventories the collection into
// music_file_metadata, the artist source for enrichment.
// -------------------------------------------------------------------------

$musicMetadataServiceFactory = new MusicMetadataServiceFactory();

$metadataScanService = new MetadataScanService(
    $musicFileMetadataRepository,
    $musicMetadataServiceFactory,
    $logger,
);

// -------------------------------------------------------------------------
// Application
// -------------------------------------------------------------------------

$application = new Application('Music Resort Tool', '1.0.0');

$application->addCommand(new MigrateCommand($migrationService));
$application->addCommand(new MigrateRefreshCommand($migrationService, $preserveTables));
$application->addCommand(new ResortMp3Command());
$application->addCommand(new DeduplicateMp3Command());
$application->addCommand(new FixExtensionsCommand());
$application->addCommand(new CleanMp3Command());
$application->addCommand(new CleanEmptyDirsCommand());
$application->addCommand(new MetadataScanCommand($metadataScanService));
$application->addCommand(new MetadataEnrichCommand($metadataEnrichService, $lastFmApiKey));
$application->addCommand(new RunAllCommand());

try {
    $application->run();
} catch (Exception $e) {
    $logger->error($e->getMessage(), ['exception' => $e::class]);
    echo $e->getMessage();
}

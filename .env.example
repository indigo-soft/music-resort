# default language
DEFAULT_LANG=en

# debug mode (true: always --dry-run)
DEBUG=false

# ---- GitHub Integration ----
# Personal Access Token with repo, issues, pull_requests scopes
GITHUB_TOKEN=ghp_...

# ---- Database (MariaDB) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=music_resort
DB_USER=root
DB_PASSWORD=

# Tables to preserve during migrate:refresh (comma-separated).
# Default if not set: migrations,processing_log
#MIGRATION_PRESERVE_TABLES=migrations,processing_log

# ---- Logging ----
# Path to the application log file. Directory is created automatically.
LOG_PATH=./storage/logs/app.log

# ---- Last FM ----
# API params for Last FM API (https://www.last.fm/api/account/create)
LASTFM_API_KEY=...
LASTFM_API_URL=https://ws.audioscrobbler.com/2.0/
LASTFM_CACHE_TTL_DAYS=30

{
    "name": "music-resort",
    "version": "1.1.0",
    "description": "CLI tool for sorting, deduplicating, fixing and cleaning music files (mp3/flac/m4a).",
    "keywords": [
        "music",
        "cli",
        "resort",
        "deduplicate"
    ],
    "private": true,
    "homepage": "https://github.com/indigo-soft/music-resort#readme",
    "bugs": {
        "url": "https://github.com/indigo-soft/music-resort/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/indigo-soft/music-resort.git"
    },
    "license": "MIT",
    "author": "github.com/indigo-soft",
    "scripts": {
        "init": "pnpm exec lefthook install && find scripts -name '*.sh' -exec chmod +x {} +",
        "release": "bash scripts/release/release.sh",
        "release:dry": "bash scripts/release/release.sh --dry",
        "release:patch": "bash scripts/release/release.sh --type=patch",
        "release:minor": "bash scripts/release/release.sh --type=minor",
        "release:major": "bash scripts/release/release.sh --type=major"
    },
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=10.0.0"
    },
    "release-it": {
        "extends": "./scripts/.release-it.json"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.0",
        "@commitlint/config-conventional": "^21.0.0",
        "lefthook": "^2.1.6"
    }
}

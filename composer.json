{
    "name": "indigo-soft/music-resort",
    "type": "project",
    "description": "Console commands for automatically sorting music files (mp3, flac, m4a) by artists in separate folders and deduplicating audio.",
    "keywords": [
        "music-resort",
        "music-deduplicate",
        "music-sort"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MusicResort\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "symfony/console": "^7.3.0",
        "symfony/finder": "^7.3.0",
        "symfony/filesystem": "^7.3.0",
        "symfony/process": "^7.3.0",
        "james-heinrich/getid3": "1.9.*",
        "symfony/string": "^7.3.0",
        "symfony/translation-contracts": "^3.6.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.86.0",
        "pestphp/pest": "^3.8.0",
        "phpstan/phpstan": "^2.1.0",
        "symfony/var-dumper": "^7.3.0"
    },
    "scripts": {
        "test": "pest -d",
        "cs": "php-cs-fixer fix --diff --dry-run",
        "fix": "php-cs-fixer fix",
        "stan": "phpstan analyse src --memory-limit=1G",
        "lint": "php-cs-fixer fix && phpstan analyse src --memory-limit=1G",
        "music:list": "php bin/console list",
        "music:all": "php bin/console music:all",
        "music:resort": "php bin/console music:resort"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}

{
    "name": "indigo-soft/music-resort",
    "type": "project",
    "description": "Console commands for automatically sorting music files (mp3, flac, m4a) by artists in separate folders and deduplicating audio.",
    "keywords": [
        "music-resort",
        "music-deduplicate",
        "music-sort"
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MusicResort\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-curl": "*",
        "symfony/console": "^v8.1.0",
        "symfony/finder": "^v8.1.0",
        "symfony/filesystem": "^v8.1.0",
        "symfony/process": "^v8.1.0",
        "james-heinrich/getid3": "^v1.9.25",
        "symfony/string": "^v8.1.0",
        "symfony/translation-contracts": "^v3.7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^v3.95.0",
        "pestphp/pest": "^v4.7.0",
        "phpstan/phpstan": "^2.2.0",
        "symfony/var-dumper": "^v8.1.0"
    },
    "scripts": {
        "test": "pest",
        "test:unit": "pest --testsuite=Unit",
        "test:integration": "pest --testsuite=Integration",
        "cs": "php-cs-fixer fix --diff --dry-run",
        "fix": "php-cs-fixer fix",
        "stan": "phpstan analyse src --memory-limit=1G",
        "lint": "php-cs-fixer fix && phpstan analyse src --memory-limit=1G",
        "music:list": "php bin/console list",
        "music:all": "php bin/console music:all",
        "music:resort": "php bin/console music:resort"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}

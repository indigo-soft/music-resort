{
    "git": {
        "commit": true,
        "commitMessage": "chore(release): v${version}",
        "tag": true,
        "tagName": "v${version}",
        "push": true,
        "requireCleanWorkingDir": true
    },
    "github": {
        "release": true,
        "releaseName": "Release v${version}",
        "tokenRef": "GITHUB_TOKEN"
    },
    "npm": {
        "publish": false,
        "version": true
    },
    "plugins": {
        "@release-it/conventional-changelog": {
            "preset": "conventionalcommits",
            "infile": "CHANGELOG.md"
        }
    }
}
